# ============================================================
# IDENTITE DE L'ASSOCIATION — obligatoire pour toute duplication
# Ces variables VITE_ sont embarquées dans le bundle frontend
# ============================================================
VITE_ASSOCIATION_NAME=Registre Communautaire Du Douar
VITE_ASSOCIATION_NAME_AR=السجل الجماعي للدوار
VITE_PLACE_NAME=Agadir n'tguida
VITE_PLACE_NAME_AR=أكادير نتكيدا
VITE_ASSOCIATION_SLUG=agadirnetguida
VITE_STORAGE_PREFIX=agadirnetguida
VITE_PUBLIC_APP_URL=https://app.agadirnetguida.com
VITE_OFFICIAL_EMAIL=agadirnetguida.asso@gmail.com

# ============================================================
# VARIABLES SERVEUR — à configurer dans Vercel (jamais VITE_)
# Non exposées au navigateur
# ============================================================
# Nom de l'association pour le contexte IA (ORCHID)
ASSOCIATION_NAME=Agadir N'Tguida
# Adresse complète pour le contexte IA
ASSOCIATION_PLACE=Douar Agadir N'Tguida, Commune de Boutrouch, Caidat de Lakhsass, Province de Sidi Ifni, Region Guelmim-Oued Noun, Maroc
# Email officiel pour le contexte IA
ASSOCIATION_EMAIL=agadirnetguida.asso@gmail.com
# URL publique de l'application (sans https://)
ASSOCIATION_URL=agadirnetguida.com
# Domaine synthétique pour les comptes habitants Supabase Auth
# IMPORTANT : ne jamais changer après création de comptes (les emails sont stockés en DB)
AUTH_EMAIL_DOMAIN=auth.agadirnetguida.local
# Contexte supplémentaire facultatif injecté dans le prompt ORCHID
ASSOCIATION_EXTRA_CONTEXT=

# ============================================================
# SUPABASE
# ============================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# IA (ORCHID)
# ============================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODELS=claude-haiku-4-5-20251001

# ============================================================
# FONCTIONNALITES OPTIONNELLES
# ============================================================
VITE_DEMO_MODE=false
VITE_DEMO_PRESENTATION=false
VITE_ADMIN_PIN=
VITE_ENABLE_INTERNAL_MODULES=false
VITE_SITE_LOCK_ENABLED=false
VITE_SITE_LOCK_PASSWORD_HASH=
VITE_SITE_LOCK_PASSWORD=
VITE_SITE_LOCK_SESSION_HOURS=12
